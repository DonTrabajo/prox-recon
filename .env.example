# Optional LLM triage layer (tools/demo.py --llm). The core recon pipeline and the
# deterministic demo do NOT need any of these — leave them unset to stay fully offline.
#
# Point OPENAI_BASE_URL at a local OpenAI-compatible runtime (e.g. Ollama) to keep
# findings on your machine, or at a hosted API if you accept sending them off-box.

# Required to enable the LLM layer. For a local runtime, any non-empty placeholder works.
OPENAI_API_KEY=

# Local example (Ollama): http://localhost:11434/v1
# Leave unset to use the default hosted OpenAI endpoint.
OPENAI_BASE_URL=

# Model name as the chosen endpoint expects it (e.g. gpt-4o-mini, or a local tag like llama3).
LLM_MODEL=gpt-4o-mini
